{
  "name": "service-jay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
